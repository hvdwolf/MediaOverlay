<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Titel -->
        <TextView
            android:id="@+id/settingsTitle"
            android:text="@string/settings_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- AUTOSTART -->
        <Switch
            android:id="@+id/switchAutostart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_autostart"
            android:layout_marginTop="16dp" />

        <!-- MINIMALISEREN -->
        <Switch
            android:id="@+id/switchMinimize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_minimize_after_start" />

        <!-- POLLING INTERVAL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_polling_interval"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/editPollingInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="@string/settings_polling_interval_hint" />

        <!-- TRANSPARANTIE -->
        <TextView
            android:id="@+id/transparencyLabel"
            android:text="@string/settings_transparency_label"
            android:layout_marginTop="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <SeekBar
            android:id="@+id/transparencySeekBar"
            android:max="255"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- PREVIEW -->
        <TextView
            android:id="@+id/previewLabel"
            android:text="@string/settings_preview_label"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <FrameLayout
            android:id="@+id/overlayPreview"
            android:layout_marginTop="8dp"
            android:layout_width="200dp"
            android:layout_height="80dp"
            android:background="#AA000000" />

        <!-- OVERLAY STIJL -->
        <TextView
            android:id="@+id/overlayStyleLabel"
            android:text="@string/settings_overlay_style"
            android:layout_marginTop="20dp"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <RadioGroup
            android:id="@+id/radioOverlayStyle"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" >

            <RadioButton
                android:id="@+id/radioStyleClassic"
                android:text="@string/settings_overlay_style_classic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <RadioButton
                android:id="@+id/radioStyleSquare"
                android:text="@string/settings_overlay_style_square"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </RadioGroup>

        <!-- OVERLAY SCALING -->
        <TextView
            android:id="@+id/txtSpeedoSizeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp"
            android:text="@string/overlay_size_title"
            android:layout_marginBottom="4dp" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/txtOverlaySizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="100%"
                android:textStyle="bold"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginBottom="4dp" />

            <SeekBar
                android:id="@+id/seekOverlaySize"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:max="6" />

        </FrameLayout>


        <!-- AUTOMATIC START -->
        <TextView
            android:id="@+id/autoStartHeader"
            android:text="@string/settings_autostart_header"
            android:textStyle="bold"
            android:textSize="16sp"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Switch
            android:id="@+id/switchStartOnPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_start_on_play" />

        <Switch
            android:id="@+id/switchStartOnAppOpen"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_start_on_app_open" />

        <TextView
            android:id="@+id/mediaAppListLabel"
            android:text="@string/settings_media_apps_label"
            android:layout_marginTop="12dp"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:id="@+id/mediaAppList"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />



    </LinearLayout>
</ScrollView>
